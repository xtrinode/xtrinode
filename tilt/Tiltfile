config.define_string('image_tag')
config.define_string('trino_tag')
config.define_string('uv')
cfg = config.parse()

image_tag = cfg.get('image_tag', 'tilt')
trino_tag = cfg.get('trino_tag', '480')
uv = cfg.get('uv', 'uv')

local_resource(
    'k3d',
    'cd .. && ./tilt/scripts/k3d-up.sh',
    deps=['scripts/k3d-up.sh'],
    auto_init=False,
)

allow_k8s_contexts('k3d-xtrinode-dev')

def image_build(name, package, port):
    docker_build(
        name,
        context='../xtrinode',
        dockerfile='../docker/Dockerfile',
        build_args={
            'APP_PACKAGE': package,
            'APP_PORT': port,
        },
        ignore=[
            'coverage.out',
            'coverage.html',
            '.git',
        ],
    )

def helm_template(name, chart, namespace, values, sets=[]):
    args = [
        'helm', 'template', name, chart,
        '--namespace', namespace,
        '--values', values,
        '--include-crds',
    ]
    for item in sets:
        args.extend(['--set', item])
    return local(' '.join(args))

def robot_cmd(args):
    return (
        "cd .. && " +
        "if ! command -v %s >/dev/null 2>&1; then " +
        "echo 'ERROR: uv is required for local e2e. Install uv or run Make with ROBOT_RUNNER=robot.'; " +
        "exit 1; " +
        "fi; " +
        "UV_CACHE_DIR=/tmp/xtrinode-uv-cache %s run --project tilt/e2e robot %s"
    ) % (uv, uv, args)

def preload_cmd():
    return "cd .. && TRINO_IMAGE_TAG=%s ./tilt/scripts/preload-local-images.sh" % trino_tag

image_build('xtrinode-operator', './cmd/operator', '8081')
image_build('xtrinode-api-server', './cmd/api-server', '8081')
image_build('xtrinode-gateway', './cmd/gateway', '8080')

k8s_yaml('deployments/namespaces.yaml')
k8s_yaml('examples/postgres-analytics.yaml', allow_duplicates=True)

k8s_yaml(helm_template(
    'xtrinode-observability',
    '../helm/xtrinode-observability',
    'monitoring',
    'deployments/values/observability.yaml',
))

k8s_yaml(helm_template(
    'xtrinode-operator',
    '../helm/xtrinode-operator',
    'xtrinode-system',
    'deployments/values/operator.yaml',
    [
        'image.repository=xtrinode-operator',
        'image.tag=%s' % image_tag,
    ],
))

k8s_yaml(helm_template(
    'xtrinode-api-server',
    '../helm/xtrinode-api-server',
    'xtrinode-system',
    'deployments/values/api-server.yaml',
    [
        'image.repository=xtrinode-api-server',
        'image.tag=%s' % image_tag,
    ],
))

k8s_yaml(helm_template(
    'xtrinode-gateway',
    '../helm/xtrinode-gateway',
    'xtrinode-gateway',
    'deployments/values/gateway.yaml',
    [
        'image.repository=xtrinode-gateway',
        'image.tag=%s' % image_tag,
    ],
))

local_resource(
    'local-image-preload',
    preload_cmd(),
    deps=['scripts/preload-local-images.sh'],
)

k8s_resource('xtrinode-operator', labels=['control-plane'], resource_deps=['local-image-preload'])
k8s_resource('xtrinode-api-server', labels=['control-plane'], port_forwards=['18081:8081'], resource_deps=['local-image-preload'])
k8s_resource('xtrinode-gateway', labels=['data-plane'], port_forwards=['18080:8080'], resource_deps=['local-image-preload'])
k8s_resource('xtrinode-gateway-redis', labels=['data-plane'], resource_deps=['local-image-preload'])
k8s_resource('xtrinode-observability-pro-operator', labels=['observability'], resource_deps=['local-image-preload'])
k8s_resource(
    new_name='xtrinode-observability-crs',
    objects=[
        'xtrinode-observability-pro-prometheus:prometheus',
        'xtrinode-observability-pro-operator:servicemonitor',
        'xtrinode-observability-pro-prometheus:servicemonitor',
    ],
    labels=['observability'],
    resource_deps=['xtrinode-observability-pro-operator'],
)
k8s_resource('postgres', labels=['data-plane'], resource_deps=['local-image-preload'])

